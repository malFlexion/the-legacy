# Speeds up docker build by excluding files the image doesn't need.
.git/
.venv/
venv/
__pycache__/
**/__pycache__/
*.pyc

# Large data files — only card_index.pkl is explicitly copied by the Dockerfile
data/scryfall-cards.json
# data/*.txt previously blanket-excluded; the RAG rebuild needs
# comprehensive-rules.txt so we let the Dockerfile's COPY pull it in.

# Training + notebooks not needed at inference time
data/training/
notebooks/
# Use scripts/* (not scripts/) so Docker still walks into the directory
# and our !exception for docker_entrypoint.sh can take effect. A bare
# `scripts/` stops traversal entirely, making the exception a no-op.
scripts/*
!scripts/docker_entrypoint.sh
tests/
# vectordb/ IS copied — RAG retrieval uses it at inference time

# Build / editor artifacts
merged-model/
# GGUF models are fetched by the Dockerfile via `ADD <release URL>`, not
# copied from the build context — no need to upload the file every deploy.
*.gguf
*.safetensors
.vscode/
.idea/
.pytest_cache/
